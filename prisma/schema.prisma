// VICTUS — منصة الخدمات (هوية مُعاد تعريفها)
// منصة تجارية محورها ثلاث خدمات مملوكة للإدارة (المختبر + السوق + الصيانة).
// مخطّط نظيف: الأساس (هوية/RBAC/جغرافيا/طبقات أفقية) + نواة الخدمات.

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ───────────────────────────── ENUMS ─────────────────────────────

enum AccountType {
  SUPER_ADMIN
  CLINIC_OWNER
  DENTIST
  SERVICE_MEMBER
  JOB_SEEKER
  ADVERTISER
}

enum AccountStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum PermissionAction {
  VIEW
  CREATE
  EDIT
  DELETE
  MANAGE
  EXPORT
}

enum DocumentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NotificationType {
  ACCOUNT
  ORDER
  MAINTENANCE
  JOB
  AD
  SYSTEM
  GENERAL
}

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
}

enum MediaKind {
  IMAGE
  DOCUMENT
  PDF
  CV
  LOGO
  AVATAR
  VIDEO
  OTHER
}

enum MediaStatus {
  ACTIVE
  DELETED
}

// نواة الخدمات
enum ServiceType {
  LAB
  MARKET
  MAINTENANCE
}

enum ServiceMode {
  OFF
  FEATURED
  EXCLUSIVE
}

enum ServiceRole {
  MANAGER
  MEMBER
}

enum CatalogCondition {
  NEW
  USED
  REFURBISHED
}

enum OrderTier {
  NORMAL
  VIP
}

enum FulfillmentStatus {
  NEW
  RECEIVED
  IN_PROGRESS
  READY
  COMPLETED
  CANCELLED
}

enum TransactionStatus {
  PENDING
  AGREED
  COMPLETED
  CANCELLED
}

// ─── jobs & recruitment ───
enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  TEMPORARY
  INTERNSHIP
}

enum JobStatus {
  DRAFT
  OPEN
  CLOSED
}

enum ApplicationStatus {
  SUBMITTED
  SCREENING
  INTERVIEW
  ACCEPTED
  REJECTED
}

// ─── advertising ───
enum CampaignStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  PAUSED
  COMPLETED
  REJECTED
}

enum AdType {
  BANNER
  SPONSORED_PRODUCT
  SPONSORED_JOB
  SPONSORED_SERVICE
}

enum AdPaymentStatus {
  UNPAID
  PENDING_REVIEW
  PAID
}

enum AdLeadType {
  IMPRESSION_GOAL
  CALL
  INQUIRY
  SALE
}

// ─── HR (per-service teams) ───
enum EmployeeStatus {
  ACTIVE
  VACATION
  SUSPENDED
  RESIGNED
  TERMINATED
}

enum LeaveType {
  ANNUAL
  SICK
  EMERGENCY
  UNPAID
}

enum LeaveStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  CANCELLED
}

enum SalaryType {
  MONTHLY
  DAILY
}

enum PayrollStatus {
  DRAFT
  FINALIZED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LEAVE
  HOLIDAY
}

// ─── maintenance service (internal, no public catalog) ───
enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum MaintenanceStatus {
  NEW // REQ- submitted by the doctor
  ASSIGNED // team received + assigned an engineer
  IN_PROGRESS // engineer started (visits + parts)
  AWAITING_CLOSURE // report written (diagnosis + totalCost), awaiting doctor acknowledgement
  COMPLETED // finalised → PartnerTransaction documented
  CANCELLED // reachable from any open state
}

// ─────────────────────────── IDENTITY & RBAC ───────────────────────────

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  phone        String?       @unique
  passwordHash String
  fullName     String
  accountType  AccountType
  status       AccountStatus @default(PENDING)

  governorateId String?
  governorate   Governorate? @relation(fields: [governorateId], references: [id])

  avatarUrl     String?
  lastLoginAt   DateTime?
  emailVerified DateTime?

  reviewedById  String?
  reviewedBy    User?     @relation("UserReviews", fields: [reviewedById], references: [id])
  reviewedUsers User[]    @relation("UserReviews")
  reviewedAt    DateTime?
  reviewNote    String?

  roles       UserRole[]
  permissions UserPermission[]
  documents   UserDocument[]

  serviceMemberships ServiceMember[]
  serviceOrders      ServiceOrder[]  @relation("OrderRequester")
  ownedClinics       Clinic[]        @relation("ClinicOwner")
  labRatings         LabRating[]     @relation("LabRatingRater")

  maintenanceRequests MaintenanceRequest[] @relation("MaintenanceRequester")
  assignedMaintenance MaintenanceRequest[] @relation("MaintenanceEngineer")
  maintenanceVisits   MaintenanceVisit[]   @relation("MaintenanceVisitEngineer")

  postedJobs       Job[]             @relation("JobPoster")
  jobApplications  JobApplication[]  @relation("JobApplicant")
  candidateProfile CandidateProfile?
  advertiser       Advertiser?
  employeeLinks    Employee[]        @relation("EmployeeUser")
  reviewedLeaves   LeaveRequest[]    @relation("LeaveReviewer")

  notifications           Notification[]
  notificationPreferences NotificationPreference[]
  auditLogs               AuditLog[]
  activityEvents          ActivityEvent[]
  mediaFiles              MediaFile[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Role {
  id          String           @id @default(cuid())
  key         String           @unique
  name        String
  isSystem    Boolean          @default(false)
  users       UserRole[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now())

  @@map("roles")
}

model Permission {
  id        String           @id @default(cuid())
  resource  String
  action    PermissionAction
  roles     RolePermission[]
  users     UserPermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model UserRole {
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId String
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// User-level overrides (grant/revoke above role).
model UserPermission {
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  allow        Boolean    @default(true)

  @@id([userId, permissionId])
  @@map("user_permissions")
}

model UserDocument {
  id        String         @id @default(cuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  fileUrl   String
  status    DocumentStatus @default(PENDING)
  createdAt DateTime       @default(now())

  @@map("user_documents")
}

// ─────────────────────────── GEOGRAPHY ───────────────────────────

model Governorate {
  id        String     @id @default(cuid())
  code      String     @unique
  nameAr    String
  nameEn    String
  districts District[]
  users     User[]
  clinics   Clinic[]
  services  Service[]
  jobs      Job[]
  candidateProfiles CandidateProfile[]

  @@map("governorates")
}

model District {
  id            String      @id @default(cuid())
  governorateId String
  governorate   Governorate @relation(fields: [governorateId], references: [id], onDelete: Cascade)
  nameAr        String
  nameEn        String

  @@map("districts")
}

// ─────────────────────────── HORIZONTAL LAYERS ───────────────────────────

model Notification {
  id      String              @id @default(cuid())
  userId  String
  user    User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  type    NotificationType    @default(GENERAL)
  event   String?
  channel NotificationChannel @default(IN_APP)
  title   String
  body    String?
  link    String?
  readAt  DateTime?
  createdAt DateTime          @default(now())

  @@index([userId, readAt])
  @@map("notifications")
}

model NotificationPreference {
  userId String
  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type   NotificationType
  inApp  Boolean          @default(true)
  email  Boolean          @default(false)
  sms    Boolean          @default(false)

  @@id([userId, type])
  @@map("notification_preferences")
}

model MediaFile {
  id         String      @id @default(cuid())
  ownerId    String
  owner      User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  url        String
  fileName   String
  mimeType   String?
  sizeBytes  Int         @default(0)
  provider   String      @default("local")
  kind       MediaKind   @default(OTHER)
  status     MediaStatus @default(ACTIVE)
  entityType String?
  entityId   String?
  createdAt  DateTime    @default(now())

  @@index([entityType, entityId])
  @@map("media_files")
}

model ActivityEvent {
  id         String   @id @default(cuid())
  actorId    String
  actor      User     @relation(fields: [actorId], references: [id], onDelete: Cascade)
  verb       String
  summary    String
  entityType String?
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@map("activity_events")
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actor      User?    @relation(fields: [actorId], references: [id])
  action     String
  entityType String?
  entityId   String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([action])
  @@map("audit_logs")
}

model SystemSetting {
  key   String @id
  group String @default("general")
  label String
  value Json

  @@map("system_settings")
}

// Brands directory — browsable by everyone, managed by admins.
model Brand {
  id        String   @id @default(cuid())
  name      String
  category  String?
  about     String?
  website   String?
  country   String?
  logoUrl   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("brands")
}

// ─────────────────────────── REQUESTER ENTITIES ───────────────────────────
// Clinics & their devices are "service requesters" only (no clinical ERP).

model Clinic {
  id            String       @id @default(cuid())
  ownerId       String
  owner         User         @relation("ClinicOwner", fields: [ownerId], references: [id])
  name          String
  phone         String?
  address       String?
  governorateId String?
  governorate   Governorate? @relation(fields: [governorateId], references: [id])
  devices       Device[]
  orders        ServiceOrder[]
  maintenanceRequests MaintenanceRequest[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([ownerId])
  @@map("clinics")
}

model Device {
  id         String   @id @default(cuid())
  clinicId   String
  clinic     Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  name       String
  brand      String?
  model      String?
  serial     String?
  warrantyEnd DateTime?
  maintenanceRequests MaintenanceRequest[]
  createdAt  DateTime @default(now())

  @@index([clinicId])
  @@map("devices")
}

// ─────────────────────────── SERVICE CORE (admin-owned) ───────────────────────────

model Service {
  id            String          @id @default(cuid())
  type          ServiceType     @unique // one canonical service per type (EXCLUSIVE)
  name          String
  about         String?
  logoUrl       String?
  phone         String?
  governorateId String?
  governorate   Governorate?    @relation(fields: [governorateId], references: [id])
  mode          ServiceMode     @default(EXCLUSIVE)
  isActive      Boolean         @default(true)
  members       ServiceMember[]
  catalogItems  CatalogItem[]
  orders        ServiceOrder[]
  priceChanges  PriceChangeLog[]
  transactions  PartnerTransaction[]
  ratings       LabRating[]
  maintenanceRequests MaintenanceRequest[]
  employees     Employee[]
  payrollRuns   PayrollRun[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@map("services")
}

model ServiceMember {
  id        String      @id @default(cuid())
  serviceId String
  service   Service     @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      ServiceRole @default(MEMBER)
  title     String?
  createdAt DateTime    @default(now())

  @@unique([serviceId, userId])
  @@index([userId])
  @@map("service_members")
}

model CatalogItem {
  id          String            @id @default(cuid())
  serviceId   String
  service     Service           @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  name        String
  description String?
  imageUrl    String?
  category    String?
  condition   CatalogCondition? // for device listings in the market
  priceNormal Decimal           @db.Decimal(14, 2)
  priceVip    Decimal?          @db.Decimal(14, 2)
  unit          String?
  stock         Decimal?        @db.Decimal(14, 2)
  isActive      Boolean         @default(true)
  sortOrder     Int             @default(0)
  orderItems  OrderItem[]
  maintenanceParts MaintenancePart[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([serviceId])
  @@map("catalog_items")
}

model ServiceOrder {
  id                String             @id @default(cuid())
  orderNumber       String             @unique // ORD-#####
  serviceId         String
  service           Service            @relation(fields: [serviceId], references: [id])
  serviceType       ServiceType
  requesterId       String
  requester         User               @relation("OrderRequester", fields: [requesterId], references: [id])
  clinicId          String?
  clinic            Clinic?            @relation(fields: [clinicId], references: [id])
  fulfillmentStatus FulfillmentStatus  @default(NEW)
  agreedTotal       Decimal?           @db.Decimal(14, 2) // order total at listed price
  currency          String             @default("IQD")
  note              String? // general case notes
  caseFiles         String[] // external URLs (STL / DICOM / images) — direct upload deferred
  cancelledById     String?
  cancelReason      String?
  items             OrderItem[]
  rating            LabRating?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([serviceId])
  @@index([requesterId])
  @@map("service_orders")
}

model OrderItem {
  id            String       @id @default(cuid())
  orderId       String
  order         ServiceOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  catalogItemId String?
  catalogItem   CatalogItem? @relation(fields: [catalogItemId], references: [id])
  name          String
  tier          OrderTier    @default(NORMAL)
  quantity      Int          @default(1)
  teeth         Int[] // FDI tooth numbers (lab manufacturing orders)
  shade         String? // VITA shade e.g. A2
  itemNotes     String?
  listedPrice   Decimal      @db.Decimal(14, 2)

  @@index([orderId])
  @@map("order_items")
}

model PriceChangeLog {
  id            String   @id @default(cuid())
  catalogItemId String
  serviceId     String
  service       Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  actorId       String
  actorName     String
  field         String
  oldValue      Decimal? @db.Decimal(14, 2)
  newValue      Decimal? @db.Decimal(14, 2)
  createdAt     DateTime @default(now())

  @@index([serviceId])
  @@map("price_change_logs")
}

// Admin documentation of every service deal (manual cut deduction reference).
model PartnerTransaction {
  id            String            @id @default(cuid())
  type          ServiceType
  serviceId     String
  service       Service           @relation(fields: [serviceId], references: [id])
  serviceName   String
  requesterId   String
  requesterName String
  referenceId   String // ORD-#### or REQ-####
  serviceLabel  String
  tier          OrderTier?
  agreedAmount  Decimal           @db.Decimal(14, 2)
  status        TransactionStatus @default(AGREED)
  createdAt     DateTime          @default(now())

  @@index([type])
  @@index([serviceId])
  @@index([createdAt])
  @@map("partner_transactions")
}

// Doctor's rating of a completed lab order (quality / speed / commitment 1–5).
model LabRating {
  id         String       @id @default(cuid())
  orderId    String       @unique
  order      ServiceOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  serviceId  String
  service    Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  raterId    String
  rater      User         @relation("LabRatingRater", fields: [raterId], references: [id])
  quality    Int
  speed      Int
  commitment Int
  comment    String?
  createdAt  DateTime     @default(now())

  @@index([serviceId])
  @@map("lab_ratings")
}

// ─────────────────────────── MAINTENANCE SERVICE ───────────────────────────
// Internal service (no public catalog). The doctor requests directly from
// /maintenance; the team assigns an engineer, logs visits + parts, writes a
// costed report, the doctor acknowledges (transparency only), then completion
// documents one PartnerTransaction at totalCost.

model MaintenanceRequest {
  id            String              @id @default(cuid())
  requestNumber String              @unique // REQ-#####
  serviceId     String
  service       Service             @relation(fields: [serviceId], references: [id])
  requesterId   String
  requester     User                @relation("MaintenanceRequester", fields: [requesterId], references: [id])
  clinicId      String?
  clinic        Clinic?             @relation(fields: [clinicId], references: [id])
  deviceId      String?
  device        Device?             @relation(fields: [deviceId], references: [id])
  deviceName    String // الجهاز المعطّل (snapshot / free text)
  description   String // وصف العطل
  priority      MaintenancePriority @default(MEDIUM)
  status        MaintenanceStatus   @default(NEW)
  mediaUrls     String[] // external image/video links (optional)

  assignedEngineerId String?
  assignedEngineer   User?   @relation("MaintenanceEngineer", fields: [assignedEngineerId], references: [id])

  acknowledgedAt DateTime? // doctor acknowledged the cost (transparency gate)
  completedAt    DateTime?
  cancelledById  String?
  cancelReason   String?

  report MaintenanceReport?
  visits MaintenanceVisit[]
  parts  MaintenancePart[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([serviceId])
  @@index([requesterId])
  @@index([status])
  @@index([assignedEngineerId])
  @@map("maintenance_requests")
}

// One report per request (written on closure). totalCost = laborCost + partsCost.
model MaintenanceReport {
  id         String             @id @default(cuid())
  requestId  String             @unique
  request    MaintenanceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  diagnosis  String // التشخيص + الإجراءات
  laborCost  Decimal            @default(0) @db.Decimal(14, 2) // الأجور IQD
  partsCost  Decimal            @default(0) @db.Decimal(14, 2) // قطع الغيار IQD (derived)
  totalCost  Decimal            @default(0) @db.Decimal(14, 2) // الإجمالي IQD
  authorId   String?
  authorName String?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@map("maintenance_reports")
}

// A site visit logged by the assigned engineer.
model MaintenanceVisit {
  id           String             @id @default(cuid())
  requestId    String
  request      MaintenanceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  engineerId   String
  engineer     User               @relation("MaintenanceVisitEngineer", fields: [engineerId], references: [id])
  engineerName String
  visitDate    DateTime
  notes        String?
  createdAt    DateTime           @default(now())

  @@index([requestId])
  @@map("maintenance_visits")
}

// A spare part used in a request. Registration only — links a market catalog
// item to compute its cost into totalCost; it does NOT touch market stock and
// creates NO separate market transaction (avoids double-documentation).
model MaintenancePart {
  id            String             @id @default(cuid())
  requestId     String
  request       MaintenanceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  catalogItemId String?
  catalogItem   CatalogItem?       @relation(fields: [catalogItemId], references: [id])
  name          String
  quantity      Int                @default(1)
  unitPrice     Decimal            @db.Decimal(14, 2) // IQD snapshot
  lineTotal     Decimal            @db.Decimal(14, 2) // IQD
  createdAt     DateTime           @default(now())

  @@index([requestId])
  @@map("maintenance_parts")
}

// ─────────────────────────── JOBS & RECRUITMENT ───────────────────────────
// Public job board: browse open to everyone, post by anyone with jobs:CREATE,
// apply open to all approved users. Applications run a simple recruiter pipeline.

model Job {
  id             String           @id @default(cuid())
  jobNumber      String           @unique // JOB-#####
  postedById     String
  postedBy       User             @relation("JobPoster", fields: [postedById], references: [id])
  title          String
  description    String?
  employmentType EmploymentType   @default(FULL_TIME)
  governorateId  String?
  governorate    Governorate?     @relation(fields: [governorateId], references: [id])
  salaryFrom     Decimal?         @db.Decimal(14, 2) // IQD
  salaryTo       Decimal?         @db.Decimal(14, 2) // IQD
  skills         String? // comma-separated
  requirements   String?
  status         JobStatus        @default(OPEN)
  applications   JobApplication[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([status])
  @@index([postedById])
  @@map("jobs")
}

model JobApplication {
  id          String            @id @default(cuid())
  jobId       String
  job         Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  applicantId String
  applicant   User              @relation("JobApplicant", fields: [applicantId], references: [id], onDelete: Cascade)
  coverLetter String?
  cvUrl       String?
  status      ApplicationStatus @default(SUBMITTED)
  note        String? // recruiter note
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([jobId, applicantId])
  @@index([applicantId])
  @@map("job_applications")
}

// Job-seeker profile (separate from the user account).
model CandidateProfile {
  id              String       @id @default(cuid())
  userId          String       @unique
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  headline        String?
  bio             String?
  governorateId   String?
  governorate     Governorate? @relation(fields: [governorateId], references: [id])
  skills          String? // comma-separated
  experienceYears Int          @default(0)
  education       String?
  cvUrl           String?
  isOpenToWork    Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@map("candidate_profiles")
}

// ─────────────────────────── ADVERTISING ───────────────────────────
// Ported from VICTUS-1: advertiser → campaign (review + payment) → professional
// AdSlot display (max 4 per page) with impression/click tracking + lead funnel.

model Advertiser {
  id        String       @id @default(cuid())
  userId    String       @unique
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  contact   String?
  campaigns AdCampaign[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@map("advertisers")
}

model AdCampaign {
  id             String          @id @default(cuid())
  campaignNumber String          @unique // CMP-#####
  advertiserId   String
  advertiser     Advertiser      @relation(fields: [advertiserId], references: [id], onDelete: Cascade)
  placements     String[]        @default([]) // AD_PLACEMENT keys, or ["ALL"]
  adType         AdType          @default(BANNER)
  title          String
  imageUrl       String? // back-compat: first image derived from mediaUrls
  targetUrl      String?
  // media
  mediaType      String          @default("SINGLE_IMAGE") // SINGLE_IMAGE | CAROUSEL | VIDEO | MIXED
  mediaUrls      String[]        @default([]) // image/video links (external: YouTube/Vimeo/MP4)
  thumbnailUrl   String?
  // CTA
  ctaType        String? // DETAILS | VISIT | CALL | WHATSAPP | BOOK | BUY | APPLY
  ctaUrl         String?
  // display options
  autoplayMuted  Boolean         @default(false)
  pinned         Boolean         @default(false)
  popup          Boolean         @default(false)
  wideBanner     Boolean         @default(false)
  // sponsored target (polymorphic): CatalogItem / Job / Service
  targetEntityType   String?
  targetEntityId     String?
  budget         Decimal         @default(0) @db.Decimal(14, 2) // IQD
  spent          Decimal         @default(0) @db.Decimal(14, 2) // IQD
  // billing
  amountDue      Decimal         @default(0) @db.Decimal(14, 2) // IQD (from pricing)
  paymentStatus  AdPaymentStatus @default(UNPAID)
  paymentRef     String?
  startDate      DateTime
  endDate        DateTime
  targetGovernorates String? // comma-separated codes
  status         CampaignStatus  @default(DRAFT)
  impressions    AdImpression[]
  clicks         AdClick[]
  leads          AdLead[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([status])
  @@index([placements], type: Gin)
  @@map("ad_campaigns")
}

model AdLead {
  id         String     @id @default(cuid())
  campaignId String
  campaign   AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  type       AdLeadType @default(INQUIRY)
  value      Decimal?   @db.Decimal(14, 2) // IQD
  note       String?
  createdAt  DateTime   @default(now())

  @@index([campaignId])
  @@map("ad_leads")
}

// Monetization pricing rules per ad type.
model AdPricing {
  id        String   @id @default(cuid())
  adType    AdType   @unique
  price     Decimal  @db.Decimal(14, 2) // IQD
  unit      String   @default("WEEKLY") // WEEKLY | MONTHLY
  isActive  Boolean  @default(true)
  updatedAt DateTime @updatedAt

  @@map("ad_pricing")
}

model AdImpression {
  id          String     @id @default(cuid())
  campaignId  String
  campaign    AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  governorate String?
  createdAt   DateTime   @default(now())

  @@index([campaignId])
  @@map("ad_impressions")
}

model AdClick {
  id          String     @id @default(cuid())
  campaignId  String
  campaign    AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  governorate String?
  createdAt   DateTime   @default(now())

  @@index([campaignId])
  @@map("ad_clicks")
}

// ─────────────────────────── HR (per-service teams) ───────────────────────────
// Each service (lab/market/maintenance) has its own staff, managed by the
// service MANAGER (or platform admin): employees · daily attendance · leaves
// (LEV-) · monthly payroll runs (PAY-) with absence-deduction payslips.

model Employee {
  id             String         @id @default(cuid())
  employeeNumber String         @unique // EMP-#####
  serviceId      String
  service        Service        @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  userId         String? // optional link to a platform account
  user           User?          @relation("EmployeeUser", fields: [userId], references: [id])
  fullName       String
  phone          String?
  position       String?
  baseSalary     Decimal        @default(0) @db.Decimal(14, 2) // IQD (monthly or daily rate)
  salaryType     SalaryType     @default(MONTHLY)
  hireDate       DateTime?
  status         EmployeeStatus @default(ACTIVE)
  attendance     Attendance[]
  leaveRequests  LeaveRequest[]
  payslips       Payslip[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([serviceId, status])
  @@map("employees")
}

// One attendance row per employee/day.
model Attendance {
  id          String           @id @default(cuid())
  employeeId  String
  employee    Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date        DateTime         @db.Date
  checkIn     DateTime?
  checkOut    DateTime?
  status      AttendanceStatus @default(PRESENT)
  lateMinutes Int              @default(0)
  workMinutes Int              @default(0)
  note        String?
  createdAt   DateTime         @default(now())

  @@unique([employeeId, date])
  @@index([employeeId, date])
  @@map("attendance")
}

// Leave request (LEV-) — approval stamps its days as LEAVE in attendance.
model LeaveRequest {
  id           String      @id @default(cuid())
  leaveNumber  String      @unique // LEV-#####
  employeeId   String
  employee     Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  type         LeaveType   @default(ANNUAL)
  startDate    DateTime    @db.Date
  endDate      DateTime    @db.Date
  days         Int
  reason       String?
  status       LeaveStatus @default(SUBMITTED)
  reviewedById String?
  reviewedBy   User?       @relation("LeaveReviewer", fields: [reviewedById], references: [id])
  reviewedAt   DateTime?
  reviewNote   String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([employeeId, status])
  @@map("leave_requests")
}

// Monthly payroll run for a service (PAY-) — generates payslips for active staff.
model PayrollRun {
  id            String        @id @default(cuid())
  payrollNumber String        @unique // PAY-#####
  serviceId     String
  service       Service       @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  year          Int
  month         Int // 1–12
  status        PayrollStatus @default(DRAFT)
  createdById   String
  payslips      Payslip[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([serviceId, year, month])
  @@index([serviceId])
  @@map("payroll_runs")
}

// Employee payslip: net = base + allowances − (absenceDeduction + manualDeduction).
model Payslip {
  id               String     @id @default(cuid())
  payrollRunId     String
  payrollRun       PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employeeId       String
  employee         Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  baseAmount       Decimal    @db.Decimal(14, 2)
  allowances       Decimal    @default(0) @db.Decimal(14, 2)
  absenceDeduction Decimal    @default(0) @db.Decimal(14, 2)
  manualDeduction  Decimal    @default(0) @db.Decimal(14, 2)
  netSalary        Decimal    @db.Decimal(14, 2)
  presentDays      Int        @default(0)
  absentDays       Int        @default(0)
  leaveDays        Int        @default(0)
  note             String?

  @@unique([payrollRunId, employeeId])
  @@index([employeeId])
  @@map("payslips")
}
